{
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "poc/webapp.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/poc(/.*)?",
      "dest": "poc/webapp.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
